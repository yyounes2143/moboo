<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
    <ImageView android:id="@+id/startImageView" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:scaleType="fitXY" android:adjustViewBounds="true" android:maxWidth="36dp" android:maxHeight="48dp" android:layout_marginEnd="10dp"/>
    <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:textSize="11sp" android:textColor="#ffffff" android:ellipsize="end" android:id="@+id/labelView" android:background="@drawable/notification_label_bg" android:paddingTop="1dp" android:paddingBottom="1dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingStart="3dp" android:paddingEnd="3dp" android:layout_marginEnd="3dp"/>
            <TextView android:textSize="14sp" android:textStyle="bold" android:ellipsize="end" android:id="@+id/title" android:layout_width="0dp" android:layout_height="wrap_content" android:maxLines="1" android:layout_weight="1" style="@style/TextAppearance.Compat.Notification.Title"/>
        </LinearLayout>
        <TextView android:textSize="14sp" android:ellipsize="end" android:id="@+id/content" android:paddingTop="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" style="@style/TextAppearance.Compat.Notification.Line2"/>
    </LinearLayout>
    <ImageView android:id="@+id/endImageView" android:visibility="visible" android:layout_width="wrap_content" android:layout_height="wrap_content" android:scaleType="fitXY" android:adjustViewBounds="true" android:maxWidth="36dp" android:maxHeight="48dp" android:layout_marginStart="10dp"/>
</LinearLayout>
