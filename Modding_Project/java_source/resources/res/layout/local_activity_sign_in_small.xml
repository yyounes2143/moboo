<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
    <ImageView android:layout_gravity="center" android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/bg_local_activity_sign_in_small" android:scaleType="fitStart"/>
    <LinearLayout android:orientation="vertical" android:paddingTop="8dp" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginEnd="46dp">
        <TextView android:textSize="14sp" android:textStyle="bold" android:ellipsize="end" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" style="@style/TextAppearance.Compat.Notification.Title"/>
        <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:textSize="13sp" android:ellipsize="end" android:id="@+id/content" android:paddingTop="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" android:layout_weight="1" style="@style/TextAppearance.Compat.Notification.Line2"/>
            <TextView android:textSize="13sp" android:textColor="#ff2651" android:id="@+id/bonusView" android:layout_width="wrap_content" android:layout_height="wrap_content" android:drawablePadding="2dp" android:drawableStart="@drawable/ic_home_widget_gift_active" android:layout_marginStart="3dp"/>
        </LinearLayout>
    </LinearLayout>
    <ImageView android:layout_gravity="end|center_vertical" android:id="@+id/endImageView" android:visibility="visible" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_local_activity_sign_in" android:scaleType="fitXY" android:adjustViewBounds="true" android:layout_marginStart="10dp"/>
</FrameLayout>
