<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
    <ImageView android:layout_gravity="center" android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/bg_local_activity_recommend_series_small" android:scaleType="centerInside"/>
    <LinearLayout android:orientation="vertical" android:paddingTop="7dp" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginEnd="46dp">
        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="#ffff2651" android:ellipsize="end" android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" style="@style/TextAppearance.Compat.Notification.Title"/>
        <TextView android:textSize="12sp" android:ellipsize="end" android:id="@+id/content" android:paddingTop="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1" style="@style/TextAppearance.Compat.Notification.Line2"/>
    </LinearLayout>
    <ImageView android:layout_gravity="end|center_vertical" android:id="@+id/endImageView" android:visibility="visible" android:layout_width="36dp" android:layout_height="48dp" android:scaleType="fitXY" android:adjustViewBounds="true" android:layout_marginStart="10dp"/>
</FrameLayout>
